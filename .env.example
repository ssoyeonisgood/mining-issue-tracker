# Backend API (ASP.NET Core reads ConnectionStrings__DefaultConnection)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=mining_issue_tracker;Username=postgres;Password=YOUR_PASSWORD

# Comma-separated frontend URLs allowed by CORS (production)
# Example: https://mining-issue-tracker.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:5173

# Frontend (copy to frontend/.env.production.local for local prod build test)
VITE_API_BASE_URL=http://localhost:5253
